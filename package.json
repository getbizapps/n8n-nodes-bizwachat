{
  "name": "n8n-nodes-bizwachat-v3",
  "version": "3.0.0",
  "description": "Hand-authored Bizwachat n8n nodes for tenant API messaging, templates, bots, and webhook triggers.",
  "keywords": [
    "n8n-community-node-package",
    "bizwachat",
    "whatsapp",
    "automation",
    "webhooks"
  ],
  "license": "MIT",
  "homepage": "https://www.bizwachat.com/",
  "author": {
    "name": "Bizwachat Team",
    "email": "hello@bizwachat.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/getbizapps/n8n-nodes-bizwachat.git"
  },
  "engines": {
    "node": ">=18.10"
  },
  "packageManager": "pnpm@9.1.4",
  "main": "index.js",
  "scripts": {
    "build": "tsc && gulp build:icons",
    "dev": "tsc --watch",
    "format": "prettier nodes credentials shared README.md --write",
    "lint": "eslint nodes credentials shared package.json",
    "lintfix": "eslint nodes credentials shared package.json --fix",
    "prepublishOnly": "npm run build && npm run lint -c .eslintrc.prepublish.js nodes credentials shared package.json"
  },
  "files": [
    "dist"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/BizwaChatTenantApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/BizwaChatV3/BizwaChatV3.node.js",
      "dist/nodes/BizwaChatV3/BizwaChatWebhookTrigger.node.js"
    ]
  },
  "devDependencies": {
	"@types/node": "^22.15.30",
    "@typescript-eslint/parser": "~5.45",
    "eslint-plugin-n8n-nodes-base": "^1.11.0",
    "gulp": "^4.0.2",
    "n8n-workflow": "~1.48.0",
    "prettier": "^2.7.1",
    "typescript": "~4.8.4"
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  },
  "bugs": {
    "url": "https://github.com/getbizapps/n8n-nodes-bizwachat/issues"
  }
}